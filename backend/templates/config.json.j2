{
  "mcpServers": {
    "{{ tool_name }}": {
      "command": "python",
      "args": ["server.py"]{% if env_vars %},
      "env": {
        {% for key, val in env_vars.items() %}
        "{{ key }}": "{{ val }}"{% if not loop.last %},{% endif %}

        {% endfor %}
      }{% endif %}

    }
  }
}
